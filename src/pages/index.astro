---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryCard from '../components/EntryCard.astro';
import { formatType, sortByDateDesc } from '../lib/content';

const works = await getCollection('works');
const shows = (await getCollection('episodes')).filter((entry) => entry.data.type === 'show');
const appearances = await getCollection('appearances');
const entries = [
  ...works.map((entry) => ({ entry, collection: 'works' })),
  ...shows.map((entry) => ({ entry, collection: 'episodes' })),
  ...appearances.map((entry) => ({ entry, collection: 'appearances' })),
].sort((a, b) => sortByDateDesc(a.entry, b.entry));
const filters = Array.from(new Set(entries.map(({ entry }) => entry.data.type))).sort();
const deathDate = '2018-06-08';
const isPosthumous = (entry) => {
  if (entry.data.tags?.includes('posthumous')) return true;
  if (!entry.data.date) return false;
  if (entry.data.date_precision === 'year') return entry.data.date > '2018';
  if (entry.data.date_precision === 'month') return entry.data.date > '2018-06';
  return entry.data.date > deathDate;
};
---
<BaseLayout title="Bourdain Index">
  <section class="hero">
    <h1>Bourdain Index</h1>
  </section>

  <div class="controls" aria-label="View controls">
    <div class="pill-row" aria-label="Filters">
      <button class="pill is-active" type="button" data-filter-clear>All</button>
      <button class="pill" type="button" data-filter-facet="posthumous">Posthumous</button>
      {filters.map((filter) => (
        <button class="pill" type="button" data-filter-type={filter}>{formatType(filter)}</button>
      ))}
    </div>
    <div class="pill-row" aria-label="Layout">
      <button class="pill is-active" type="button" data-view="timeline">Timeline</button>
      <button class="pill" type="button" data-view="cards">Cards</button>
    </div>
  </div>

  <ol class="stream" data-stream data-view="timeline">
    {entries.map(({ entry, collection }) => (
      <li class="stream-item" data-type={entry.data.type} data-posthumous={isPosthumous(entry) ? 'true' : 'false'}>
        <EntryCard entry={entry} collection={collection} />
      </li>
    ))}
  </ol>

  <script>
    const stream = document.querySelector('[data-stream]');
    const clearButton = document.querySelector('[data-filter-clear]');
    const typeButtons = document.querySelectorAll('[data-filter-type]');
    const facetButtons = document.querySelectorAll('[data-filter-facet]');
    const viewButtons = document.querySelectorAll('[data-view]');

    const updateFilters = () => {
      const activeTypes = Array.from(typeButtons)
        .filter((button) => button.classList.contains('is-active'))
        .map((button) => button.getAttribute('data-filter-type'));
      const posthumousOnly = Array.from(facetButtons).some(
        (button) => button.getAttribute('data-filter-facet') === 'posthumous' && button.classList.contains('is-active'),
      );
      const hasFilters = activeTypes.length > 0 || posthumousOnly;

      clearButton?.classList.toggle('is-active', !hasFilters);

      document.querySelectorAll('.stream-item').forEach((item) => {
        const matchesType = activeTypes.length === 0 || activeTypes.includes(item.getAttribute('data-type'));
        const matchesPosthumous = !posthumousOnly || item.getAttribute('data-posthumous') === 'true';
        item.hidden = !matchesType || !matchesPosthumous;
      });
    };

    clearButton?.addEventListener('click', () => {
      typeButtons.forEach((button) => button.classList.remove('is-active'));
      facetButtons.forEach((button) => button.classList.remove('is-active'));
      updateFilters();
    });

    [...typeButtons, ...facetButtons].forEach((button) => {
      button.addEventListener('click', () => {
        button.classList.toggle('is-active');
        updateFilters();
      });
    });

    viewButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const view = button.getAttribute('data-view');
        viewButtons.forEach((item) => item.classList.toggle('is-active', item === button));
        stream?.setAttribute('data-view', view ?? 'timeline');
      });
    });
  </script>
</BaseLayout>
