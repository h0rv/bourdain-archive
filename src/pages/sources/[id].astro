---
import { getCollection } from 'astro:content';
import archiveRegistry from '../../../archive/derived/web-archive-registry.json';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('sources');
  return entries.map((entry) => ({ params: { id: entry.data.id }, props: { entry } }));
}

const { entry } = Astro.props;
const archive = archiveRegistry.registry[entry.data.url as keyof typeof archiveRegistry.registry];
---
<BaseLayout title={entry.data.title} description={entry.data.notes ?? entry.data.title}>
  <article>
    <h1 class="page-title">{entry.data.title}</h1>
    <p class="meta">{entry.data.type} · accessed {entry.data.accessed}</p>
    {entry.data.notes && <p class="lede">{entry.data.notes}</p>}
    <section class="detail-box">
      <h2>URL</h2>
      <p><a href={entry.data.url}>{entry.data.url}</a></p>
    </section>
    {archive && (
      <section class="detail-box">
        <h2>Archive</h2>
        <ul class="badges" aria-label="Archive links">
          <li><a class="badge" href={archive.latest_url}>Latest snapshot</a></li>
          <li><a class="badge" href={archive.calendar_url}>Calendar</a></li>
          <li><a class="badge" href={archive.save_url}>Save snapshot</a></li>
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
