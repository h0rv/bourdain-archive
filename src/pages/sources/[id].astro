---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('sources');
  return entries.map((entry) => ({ params: { id: entry.data.id }, props: { entry } }));
}

const { entry } = Astro.props;
---
<BaseLayout title={entry.data.title} description={entry.data.notes ?? entry.data.title}>
  <article>
    <h1 class="page-title">{entry.data.title}</h1>
    <p class="meta">{entry.data.type} · accessed {entry.data.accessed}</p>
    {entry.data.notes && <p class="lede">{entry.data.notes}</p>}
    <section class="detail-box">
      <h2>URL</h2>
      <p><a href={entry.data.url}>{entry.data.url}</a></p>
    </section>
  </article>
</BaseLayout>
