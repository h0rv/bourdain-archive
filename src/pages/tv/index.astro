---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import { sortByDateDesc } from '../../lib/content';

const entries = (await getCollection('episodes')).sort(sortByDateDesc);
const shows = entries.filter((entry) => entry.data.type === 'show');
const episodes = entries.filter((entry) => entry.data.type !== 'show');
const showNames = Array.from(new Set([...shows.map((entry) => entry.data.title), ...episodes.map((entry) => entry.data.show).filter(Boolean)]));
---
<BaseLayout title="TV">
  <h1 class="page-title">TV</h1>
  {showNames.map((showName) => {
    const showEntry = shows.find((entry) => entry.data.title === showName);
    const showEpisodes = episodes.filter((entry) => entry.data.show === showName);
    return (
      <section>
        <h2 class="section-heading">{showName}</h2>
        <div class="card-list">
          {showEntry && <EntryCard entry={showEntry} collection="episodes" />}
          {showEpisodes.map((entry) => <EntryCard entry={entry} collection="episodes" />)}
        </div>
      </section>
    );
  })}
</BaseLayout>
