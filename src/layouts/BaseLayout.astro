---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const siteName = 'Bourdain Archive';
const { title = siteName, description = 'Anthony Bourdain archive.' } = Astro.props;
const pageTitle = title === siteName ? siteName : `${title} · ${siteName}`;
const withBase = (path: string) => `${import.meta.env.BASE_URL}${path.replace(/^\//, '')}`;
const navItems = [
  { href: withBase('/'), label: 'Timeline' },
  { href: withBase('/sources/'), label: 'Sources' },
  { href: withBase('/about/'), label: 'About' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href={withBase('/favicon.ico')} sizes="any" />
    <link rel="icon" href={withBase('/favicon.png')} type="image/png" />
    <link rel="apple-touch-icon" href={withBase('/apple-touch-icon.png')} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={withBase('/')} aria-label="Bourdain Archive home">
        <img
          class="brand-mark"
          src="https://d1w8c6s6gmwlek.b-cdn.net/trendyteeshop.com/overlays/389/644/38964494.png"
          alt="Cook Free or Die"
          width="96"
          height="96"
        />
        <span class="brand-copy">
          <span class="brand-name">Bourdain Archive</span>
          <span class="brand-kicker">cook free or die</span>
        </span>
      </a>
      <nav class="site-nav" aria-label="Primary navigation">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main class="site-main">
      <slot />
    </main>

  </body>
</html>
