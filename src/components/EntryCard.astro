---
import linkPreviewCache from '../../archive/derived/link-previews.json';
import { availabilityBadges, entryHref, entryTitle, formatDate, formatType, previewForEntry, sourceTimelineDate, statusClass, visibleStatus } from '../lib/content';

interface Props {
  entry: any;
  collection: string;
  showSummary?: boolean;
}

const { entry, collection, showSummary = true } = Astro.props;
const data = entry.data;
const href = entryHref(collection, data.id);
const badges = collection === 'sources' ? [{ field: 'source', label: 'Source', url: data.url }] : availabilityBadges(data.availability);
const preview = previewForEntry(entry, linkPreviewCache.previews);
const isWebPreview = !data.image_url && Boolean(preview.url);
const timelineDate = collection === 'sources' ? sourceTimelineDate(data) : { date: data.date, precision: data.date_precision };
const summary = data.summary ?? data.notes ?? 'Source record.';
const status = data.status ?? 'confirmed';
const displayStatus = visibleStatus(status);
---
<article class="card" data-entry data-type={data.type} data-collection={collection}>
  <a class={`card-media ${isWebPreview ? 'is-web-preview' : ''}`} href={href} aria-label={entryTitle(entry)}>
    {preview.image ? (
      <img src={preview.image} alt="" loading="lazy" />
    ) : (
      <span class="media-fallback">
        {preview.favicon && <img class="media-favicon" src={preview.favicon} alt="" loading="lazy" />}
        <span class="media-label">{preview.label}</span>
        {preview.url && <span class="media-url">{preview.url}</span>}
      </span>
    )}
  </a>
  <div class="card-body">
    <h2><a href={href}>{entryTitle(entry)}</a></h2>
    <p class="meta">
      {formatType(data.type)} · {formatDate(timelineDate.date, timelineDate.precision)}
      {displayStatus && <> · <span class={`badge ${statusClass(displayStatus)}`}>{displayStatus}</span></>}
    </p>
    {showSummary && <p class="summary">{summary}</p>}
    {data.tags?.length > 0 && (
      <ul class="tag-list" aria-label="Tags">
        {data.tags.slice(0, 6).map((tag: string) => <li class="tag">{tag}</li>)}
      </ul>
    )}
    <ul class="badges" aria-label="Availability">
      {badges.map((badge) => <li class="badge">{badge.label}</li>)}
    </ul>
  </div>
</article>
