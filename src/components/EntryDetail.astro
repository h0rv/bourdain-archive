---
import linkPreviewCache from '../../archive/derived/link-previews.json';
import BaseLayout from '../layouts/BaseLayout.astro';
import { availabilityBadges, entryHref, entryTitle, findByDataId, formatDate, formatType, previewForUrl, statusClass, visibleStatus } from '../lib/content';

interface Props {
  entry: any;
  collection: string;
  sources: any[];
  relatedEntries: any[];
}

const { entry, sources, relatedEntries } = Astro.props;
const data = entry.data;
const title = entryTitle(entry);
const sourceRefs = (data.sources ?? []).map((id: string) => findByDataId(sources, id)).filter(Boolean);
const relatedRefs = (data.related ?? []).map((id: string) => relatedEntries.find((item: any) => item.entry.data.id === id)).filter(Boolean);
const badges = availabilityBadges(data.availability);
const availabilityPreviews = badges.map((badge) => ({ ...badge, preview: previewForUrl(badge.url, linkPreviewCache.previews) }));
const displayStatus = visibleStatus(data.status);
---
<BaseLayout title={title} description={data.summary}>
  <article>
    <h1 class="page-title">{title}</h1>
    <p class="meta">
      {formatType(data.type)}
      {data.date ? ` · ${formatDate(data.date, data.date_precision)}` : ''}
      {displayStatus && <> · <span class={`badge ${statusClass(displayStatus)}`}>{displayStatus}</span></>}
    </p>

    <p class="lede">{data.summary}</p>

    <div class="detail-grid">
      <section class="detail-box availability-box">
        <h2>Availability</h2>
        <div class="link-preview-list">
          {availabilityPreviews.map((badge) => (
            badge.url ? (
              <div class="link-preview">
                <span class="link-preview-media">
                  {badge.preview.image ? (
                    <img src={badge.preview.image} alt="" loading="lazy" />
                  ) : badge.preview.favicon ? (
                    <img class="link-preview-favicon" src={badge.preview.favicon} alt="" loading="lazy" />
                  ) : (
                    <span>{badge.label}</span>
                  )}
                </span>
                <span class="link-preview-copy">
                  <strong>{badge.label}</strong>
                  {badge.preview.host && <span>{badge.preview.host}</span>}
                  <code>{badge.url}</code>
                  <span class="link-preview-actions">
                    <a href={badge.url}>Open</a>
                    {badge.preview.archive && <a href={badge.preview.archive.latest_url}>Archive</a>}
                  </span>
                </span>
              </div>
            ) : (
              <p class="meta">{badge.label}</p>
            )
          ))}
        </div>
      </section>

      {data.tags?.length > 0 && (
        <section class="detail-box">
          <h2>Tags</h2>
          <ul class="tag-list">
            {data.tags.map((tag: string) => <li class="tag">{tag}</li>)}
          </ul>
        </section>
      )}

      {data.people?.length > 0 && (
        <section class="detail-box">
          <h2>People</h2>
          <ul class="clean-list">
            {data.people.map((person: string) => <li>{person}</li>)}
          </ul>
        </section>
      )}

      {data.places?.length > 0 && (
        <section class="detail-box">
          <h2>Places</h2>
          <ul class="clean-list">
            {data.places.map((place: string) => <li>{place}</li>)}
          </ul>
        </section>
      )}
    </div>

    <section class="detail-box">
      <h2>Sources</h2>
      {sourceRefs.length > 0 ? (
        <ul class="clean-list">
          {sourceRefs.map((source: any) => (
            <li><a href={entryHref('sources', source.data.id)}>{source.data.title}</a> <span class="meta">({source.data.type})</span></li>
          ))}
        </ul>
      ) : (
        <p class="meta">Unsourced.</p>
      )}
    </section>

    <section class="detail-box">
      <h2>Related</h2>
      {relatedRefs.length > 0 ? (
        <ul class="clean-list">
          {relatedRefs.map((item: any) => (
            <li><a href={entryHref(item.collection, item.entry.data.id)}>{entryTitle(item.entry)}</a></li>
          ))}
        </ul>
      ) : (
        <p class="meta">None.</p>
      )}
    </section>
  </article>
</BaseLayout>
